FROM python:3.14-slim

WORKDIR /app

# System dependencies for PyTorch and image processing
RUN apt-get update && apt-get install -y \
    build-essential \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install pix2tex with the api extras — this pulls in
# fastapi, uvicorn, python-multipart, and streamlit
RUN pip install "pix2tex[api]"

# Download the model weights at build time so the container
# starts up immediately rather than downloading on first request
RUN python -c "from pix2tex.cli import LatexOCR; LatexOCR()"

EXPOSE 8502

CMD ["python", "-m", "pix2tex.api.run"]